<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — fully dark for ORBIT -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#00D4FF</item>
        <item name="colorPrimaryDark">#07070F</item>
        <item name="colorAccent">#7B2FBE</item>
        <item name="android:windowBackground">#07070F</item>
        <item name="android:statusBarColor">#07070F</item>
        <item name="android:navigationBarColor">#07070F</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>

</resources>
