{
  "appId": "com.orbit.news",
  "appName": "ORBIT",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#07070F",
      "overlaysWebView": true
